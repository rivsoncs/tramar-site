        "blur": "24px",
        "spread": "0",
        "color": "rgba(26, 31, 38, 0.10)"
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "24px",
        "blur": "48px",
